#!/usr/bin/env bash

cd "$1"

REMOTE=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || exit 0)

# echo "✅ $PWD ⟵ '$REMOTE'"

if [[ -n "$REMOTE" ]]; then
    echo "✅ $PWD ⟵ $REMOTE"
    git fetch --quiet --all --tags
    (git remote update -p 2>&1 | egrep -v '^Fetching ')
    git pull --quiet --rebase
fi
