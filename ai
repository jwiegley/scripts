#!/usr/bin/env bash

# Strict error handling
set -euo pipefail

DEFAULT_CLAUDE_MODEL="opus"
DEFAULT_OMLX_MODEL="Qwen3.6-27B-MLX-8bit"
DEFAULT_LITELLM_MODEL="hera/omlx/$DEFAULT_OMLX_MODEL"

CONTEXT=normal
if [[ $PWD =~ /pos(itron)?/ || $PWD =~ /tron/ || $PWD =~ /home/jwiegley/ ]]; then
    if [[ -d $HOME/.config/claude/positron ]]; then
        CONTEXT=positron
    fi
elif [[ $PWD =~ /git-ai/ ]]; then
    if [[ -d $HOME/.config/claude/git-ai ]]; then
        CONTEXT=git-ai
    fi
elif [[ -d $HOME/.config/claude/personal ]]; then
    CONTEXT=personal
fi

# if [[ $CONTEXT != normal ]]; then
#     export GIT_AI_API_KEY=$(pass api.usegitai.com | head -1)
# fi

# Fix bundled ripgrep on Asahi Linux (16KB pages break jemalloc)
fix_ripgrep_for_asahi() {
    # Only needed on aarch64 with 16KB pages
    [[ "$(uname -m)" == "aarch64" ]] || return 0
    [[ "$(getconf PAGESIZE)" == "16384" ]] || return 0

    # Find the npx cache directory for claude-code
    local npx_cache="$HOME/.npm/_npx"
    [[ -d "$npx_cache" ]] || return 0

    # Find and fix any broken ripgrep binaries
    local rg_path
    for rg_path in "$npx_cache"/*/node_modules/@anthropic-ai/claude-code/vendor/ripgrep/arm64-linux/rg; do
        [[ -e "$rg_path" ]] || continue

        # Skip if already a symlink to system rg
        [[ -L "$rg_path" ]] && continue

        # Test if the bundled rg works
        if ! "$rg_path" --version &>/dev/null; then
            # Replace with system ripgrep
            if command -v rg &>/dev/null; then
                mv "$rg_path" "${rg_path}.broken" 2>/dev/null || true
                ln -sf "$(command -v rg)" "$rg_path"
            fi
        fi
    done
}

# Default configuration
if [[ -x /etc/profiles/per-user/johnw/bin/claude ]]; then
    claude_cmd="/etc/profiles/per-user/johnw/bin/claude"
elif [[ -x $HOME/.nix-profile/bin/claude ]]; then
    claude_cmd="$HOME/.nix-profile/bin/claude"
else
    claude_cmd="claude"
fi
claude_args=(--model $DEFAULT_CLAUDE_MODEL --effort max --dangerously-skip-permissions)

droid_cmd="droid"
opencode_cmd="opencode"
codex_cmd="codex"
codex_args=(--ask-for-approval never)
enable_mitm=false
enable_control=false
enable_checks=true

cmd=("$claude_cmd" "${claude_args[@]}")

export ANTHROPIC_MODEL=sonnet
export COLORTERM=truecolor
export CLAUDE_CONFIG_DIR=$HOME/.claude

case $CONTEXT in
    personal)
        export ANTHROPIC_MODEL=$DEFAULT_CLAUDE_MODEL
        export CLAUDE_CONFIG_DIR=$HOME/.config/claude/personal
        ;;
    positron)
        export ANTHROPIC_MODEL=$DEFAULT_CLAUDE_MODEL
        export CLAUDE_CONFIG_DIR=$HOME/.config/claude/positron
        ;;
    git-ai)
        export CLAUDE_CONFIG_DIR=$HOME/.config/claude/git-ai
        ;;
esac

# Usage information
usage() {
    local prog
    prog=$(basename "$0")
    cat <<EOF
Usage: $prog [OPTIONS] [-- TOOL-ARGS...]

Launch an AI coding tool (Claude Code by default), tweaking which backend
runs and how, based on the options below.

Tool selection:
    --droid           Use Factory Droid instead of Claude Code
    --opencode        Use opencode instead of Claude Code
    --codex           Use codex instead of Claude Code
    --npx             Run Claude Code via 'npx @anthropic-ai/claude-code'
    --local           Use opencode against the local LiteLLM model

Command wrappers:
    --sandbox         Wrap the command in 'docker sandbox run'
    --develop         Wrap the command in 'nix develop --command'
    --nix             cd to the NixOS config (/etc/nixos or ~/src/nix) first

Config context:
    --personal        Use the 'personal' Claude config directory
    --work, --positron  Use the 'positron' Claude config directory
    --git-ai          Use the 'git-ai' Claude config directory

Alternate backends (each requires a MODEL argument):
    --litellm MODEL   Route Claude to the LiteLLM gateway (litellm.vulcan.lan)
    --llama-cpp MODEL Route Claude to a local llama.cpp server (localhost:8080)
    --ollama MODEL    Route Claude to a local Ollama server (localhost:11434)

Toggles:
    --mitm            Enable MITM proxy on localhost:9999
    --control         Enable browser control extension (requires 'pass')
    --no-check        Skip preflight tool checks
    -h, --help        Show this help message

Passing flags to the underlying tool:
    Option parsing stops at the first '--' or the first argument that isn't
    one of the options above (a prompt, or a tool flag like --resume), and
    the rest is forwarded to the tool verbatim. '--' is therefore optional:
    'ai --resume' and 'ai -- --resume' are equivalent.

Examples:
    $prog --mitm
    $prog --personal --resume            # --resume is forwarded to the tool
    $prog --llama-cpp qwen3 -p "review this repo"
    $prog "fix the failing test"
EOF
    exit 0
}

# Error handler
error() {
    echo "Error: $1" >&2
    exit 1
}

# Point Claude at an alternative Anthropic-compatible backend: set the auth
# token and base URL, pin every model slot Claude Code consults to MODEL, and
# add it to the launch command too.
#   Usage: use_backend AUTH_TOKEN BASE_URL MODEL
use_backend() {
    export ANTHROPIC_AUTH_TOKEN=$1
    export ANTHROPIC_BASE_URL=$2
    export ANTHROPIC_MODEL=$3
    export CLAUDE_CODE_SUBAGENT_MODEL=$3
    export ANTHROPIC_DEFAULT_OPUS_MODEL=$3
    export ANTHROPIC_DEFAULT_SONNET_MODEL=$3
    export ANTHROPIC_DEFAULT_HAIKU_MODEL=$3
    cmd+=(--model "$3")
}

# Preflight checks for Claude Code session tools
preflight_checks() {
    local config_dir="${CLAUDE_CONFIG_DIR:-$HOME/.config/claude}"
    local results=()
    local warnings=()

    # git-ai
    if command -v git-ai &>/dev/null; then
        local gitai_ver
        gitai_ver=$(git-ai --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1) || true
        local git_chain
        git_chain=$(whither git 2>/dev/null) || true
        if [[ "$git_chain" == *git-ai* ]]; then
            results+=("git-ai ${gitai_ver:-?} (wrapping git)")
        else
            results+=("git-ai ${gitai_ver:-?}")
            warnings+=("git is not wrapped by git-ai")
        fi
    else
        warnings+=("git-ai not found")
    fi

    # Output
    echo "Preflight:"
    for r in "${results[@]}"; do
        echo "  ✓ $r"
    done
    for w in "${warnings[@]}"; do
        echo "  ✗ $w"
    done
}

# Parse our own options; forward everything else to the underlying tool.
# Parsing stops at the first '--' (consumed) or the first argument that is not
# one of our options -- a prompt, or a tool flag such as --resume -- and the
# rest is passed through verbatim. So '--' is optional: `ai --resume` and
# `ai -- --resume` behave identically.
while (($#)); do
    case $1 in
        --) shift; break ;;

        --droid)            cmd=("$droid_cmd"); shift ;;
        --opencode)         cmd=("$opencode_cmd"); shift ;;
        --codex)            export CODEX_SQLITE_HOME="/var/tmp/codex-sqlite-${USER}-$(hostname -s)"; cmd=("$codex_cmd" "${codex_args[@]}"); shift ;;
        --npx)              cmd=(npx @anthropic-ai/claude-code "${claude_args[@]}"); shift ;;

        --sandbox)          cmd=(docker sandbox run "${cmd[@]}"); shift ;;
        --nix)
            if [[ -d /etc/nixos ]]; then
                cd /etc/nixos
            elif [[ -d ~/src/nix ]]; then
                cd ~/src/nix
            fi
            shift
            ;;
        --develop)          cmd=(nix develop --command "${cmd[@]}"); shift ;;

        --work|--positron)  export CLAUDE_CONFIG_DIR=$HOME/.config/claude/positron; shift ;;
        --personal)         export CLAUDE_CONFIG_DIR=$HOME/.config/claude/personal; shift ;;
        --git-ai)           export CLAUDE_CONFIG_DIR=$HOME/.config/claude/git-ai; shift ;;

        --local)
            cmd=("$opencode_cmd" --model "litellm/$DEFAULT_LITELLM_MODEL")
            # cmd=("$opencode_cmd" --model "omlx/$DEFAULT_OMLX_MODEL")
            shift
            ;;

        --litellm)   [[ $# -ge 2 ]] || error "$1 requires a MODEL argument"; use_backend "$(pass litellm.vulcan.lan | head -1)" https://litellm.vulcan.lan "$2"; shift 2 ;;
        --llama-cpp) [[ $# -ge 2 ]] || error "$1 requires a MODEL argument"; use_backend llama-cpp http://localhost:8080 "$2"; shift 2 ;;
        --ollama)    [[ $# -ge 2 ]] || error "$1 requires a MODEL argument"; use_backend ollama http://localhost:11434 "$2"; shift 2 ;;

        --mitm)             enable_mitm=true; shift ;;
        --control)          enable_control=true; shift ;;
        --no-check)         enable_checks=false; shift ;;

        -h|--help)          usage ;;

        *) break ;;   # prompt, or a tool flag like --resume: forward the rest
    esac
done

# Configure MITM proxy if requested
if [[ "$enable_mitm" == true ]]; then
    export NODE_TLS_REJECT_UNAUTHORIZED=0
    export HTTP_PROXY=http://localhost:9999
    export HTTPS_PROXY=http://localhost:9999
fi

# Configure browser control if requested
if [[ "$enable_control" == true ]]; then
    if ! command -v pass >/dev/null 2>&1; then
        error "pass command not found. Required for --control option."
    fi

    if ! EXTENSION_SECRET=$(pass browser-control.mcp 2>/dev/null | head -1); then
        error "Failed to retrieve extension secret from pass"
    fi
    export EXTENSION_SECRET
fi

# Fix ripgrep on Asahi Linux before launching
fix_ripgrep_for_asahi

# Run preflight checks
if [[ "$enable_checks" == true ]]; then
    preflight_checks
fi

# EXEC_TRACE=1: print resolved argv and watched env (redacted), exit 0.
# Used for parity testing against the Python port (ai.py).
if [[ "${EXEC_TRACE:-0}" == "1" ]]; then
    printf '%s\n' "ARGV: ${cmd[*]} $*"
    env | sort | grep -E '^(ANTHROPIC_|CLAUDE_|COLORTERM=|HTTP_PROXY=|HTTPS_PROXY=|NODE_TLS_REJECT_UNAUTHORIZED=|EXTENSION_SECRET=)' | sed -E 's/(TOKEN|SECRET|KEY|PASSWORD)=.*/\1=<REDACTED>/'
    exit 0
fi

# Rename tmux window to reflect the active Claude context
if [[ -n "${TMUX:-}" ]]; then
    tmux rename-window "$(basename "$CLAUDE_CONFIG_DIR")" 2>/dev/null || true
fi

if [[ $PWD =~ /j(ohnw|wiegley)$ ]]; then
    if [[ -d /etc/nixos ]]; then
        cd /etc/nixos
    elif [[ -d ~/src/nix ]]; then
        cd ~/src/nix
    elif [[ -d ~/.config/home-manager ]]; then
        cd ~/.config/home-manager
    fi
fi

# Execute the command with all forwarded arguments
exec "${cmd[@]}" "$@"
