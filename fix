#!/usr/bin/env bash

AI=claude
if [[ $1 == --opencode ]]; then
    AI=opencode
    shift 1
fi

CUR="$PWD"
for i in "$@" ; do
    cd "$CUR"
    if [[ ! -d fix-${i} ]]; then
        work fix-${i}
        ( cd fix-${i} ;                                                 \
          de ;                                                          \
          direnv allow . ;                                              \
          case $AI in                                                   \
              claude)                                                   \
                  spawn "ai --model opus --effort max '/fix $i'" ;;     \
              opencode)                                                 \
                  spawn "ai --opencode '/fix $i'" ;;                    \
          esac                                                          \
        )
    fi
done
