#!/usr/bin/env bash

# flatten-recordings — Move .m4a files from subdirectories of ~/Recordings
# up to ~/Recordings, transcribe each one, then archive the original
# audio to ~/Audio/Recordings.
#
# Structured, timestamped log: ~/Library/Logs/flatten-recordings.log

set -uo pipefail

recordings_dir="$HOME/Recordings"
archive_dir="$HOME/Audio/Recordings"
prompt_file="$HOME/doc/post-process.md"
transcribe_model="Qwen3.6-27B-Instruct"

# Give up transcribing a single file after this many failed attempts, so a
# permanently-bad recording isn't re-transcribed (an expensive call) on every
# run forever.
max_attempts=5

log_dir="$HOME/Library/Logs"
log_file="$log_dir/flatten-recordings.log"
lock_dir="$log_dir/.flatten-recordings.lock"
# Per-file transcription failure counters. Kept under ~/Library/Logs (local)
# rather than in ~/Recordings so they don't sync to iCloud.
state_dir="$log_dir/flatten-recordings.state"
session_id="$$.$(date +%s)"
start_epoch=$(date +%s)

mkdir -p "$log_dir"

exit_code=0
subdir_moved=0
move_failed=0
ds_removed=0
empty_dirs_removed=0
transcribed=0
transcribe_failed=0
transcribe_gave_up=0
archive_failed=0

log() {
    printf '%s session=%s %s\n' \
        "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$session_id" "$*" >>"$log_file"
}

# Single-instance guard. flock(1) isn't available here, so use an atomic
# mkdir lock with a PID file. A lock left behind by a crashed run whose PID
# is no longer alive is reclaimed. This runs before the EXIT trap is
# installed, so the "already running" path never removes the live owner's lock.
acquire_lock() {
    if mkdir "$lock_dir" 2>/dev/null; then
        printf '%s\n' "$$" >"$lock_dir/pid"
        return 0
    fi
    local owner
    owner=$(cat "$lock_dir/pid" 2>/dev/null)
    if [ -n "$owner" ] && kill -0 "$owner" 2>/dev/null; then
        return 1
    fi
    log "reclaiming stale lock pid=${owner:-unknown}"
    rm -rf "$lock_dir"
    mkdir "$lock_dir" 2>/dev/null || return 1
    printf '%s\n' "$$" >"$lock_dir/pid"
    return 0
}

if ! acquire_lock; then
    log "skip reason=already_running"
    exit 0
fi

on_exit() {
    local rc=$?
    trap - EXIT INT TERM HUP
    if [ "$rc" -ne 0 ] && [ "$exit_code" -eq 0 ]; then
        exit_code="$rc"
    fi
    rm -rf "$lock_dir"
    local duration=$(( $(date +%s) - start_epoch ))
    local result="ok"
    [ "$exit_code" -ne 0 ] && result="error"
    log "result=$result exit=$exit_code duration_s=$duration" \
        "subdir_moved=$subdir_moved move_failed=$move_failed" \
        "ds_removed=$ds_removed empty_dirs_removed=$empty_dirs_removed" \
        "transcribed=$transcribed transcribe_failed=$transcribe_failed" \
        "transcribe_gave_up=$transcribe_gave_up archive_failed=$archive_failed"
    exit "$exit_code"
}
trap on_exit EXIT INT TERM HUP

log "start pid=$$ host=$(hostname -s 2>/dev/null || echo unknown) user=$(id -un)"
log "config recordings_dir=$recordings_dir archive_dir=$archive_dir" \
    "prompt=$prompt_file model=$transcribe_model"

if ! command -v transcribe >/dev/null 2>&1; then
    log "ERROR setup reason=transcribe_not_on_PATH PATH=$PATH"
    exit_code=1
    exit 1
fi

if [ ! -f "$prompt_file" ]; then
    log "WARN setup reason=prompt_missing path=$prompt_file"
fi

if [ ! -d "$recordings_dir" ]; then
    log "skip reason=recordings_dir_missing path=$recordings_dir"
    exit 0
fi

# Step 1: lift any .m4a files in subdirectories up to ~/Recordings.
while IFS= read -r -d '' file; do
    dest="$recordings_dir/$(basename "$file")"
    if [ -e "$dest" ]; then
        log "ERROR move_subdir reason=target_exists file=$file dest=$dest"
        move_failed=$((move_failed + 1))
        exit_code=1
    elif mv "$file" "$dest" >>"$log_file" 2>&1; then
        log "moved subdir->top: $file"
        subdir_moved=$((subdir_moved + 1))
    else
        rc=$?
        log "ERROR move_subdir rc=$rc file=$file"
        move_failed=$((move_failed + 1))
        exit_code=1
    fi
done < <(find -L "$recordings_dir"/ -mindepth 2 -type f -name '*.m4a' -print0 2>/dev/null)

# Step 2: macOS-leftover .DS_Store cleanup inside subdirectories.
while IFS= read -r -d '' file; do
    if rm -f "$file"; then
        log "removed ds_store: $file"
        ds_removed=$((ds_removed + 1))
    fi
done < <(find -L "$recordings_dir"/ -mindepth 2 -name '.DS_Store' -print0 2>/dev/null)

# Step 3: remove any subdirectories that are now empty.
while IFS= read -r -d '' dir; do
    if rmdir "$dir" 2>/dev/null; then
        log "removed empty_dir: $dir"
        empty_dirs_removed=$((empty_dirs_removed + 1))
    fi
done < <(find -L "$recordings_dir"/ -mindepth 1 -depth -type d -print0 2>/dev/null)

# Step 4: transcribe every top-level .m4a file, then archive the audio.
mkdir -p "$archive_dir" "$state_dir"

shopt -s nullglob
files=("$recordings_dir"/*.m4a)
shopt -u nullglob

if [ "${#files[@]}" -eq 0 ]; then
    log "transcribe found=0"
else
    log "transcribe found=${#files[@]}"
    for file in "${files[@]}"; do
        base=$(basename "$file")
        fail_file="$state_dir/$base.fail"

        # Give-up budget: skip a file that has already failed max_attempts
        # times. A recording modified since its last failure (newer than its
        # counter file) gets a fresh budget.
        attempts=0
        if [ -f "$fail_file" ]; then
            if [ "$file" -nt "$fail_file" ]; then
                rm -f "$fail_file"
            else
                attempts=$(cat "$fail_file" 2>/dev/null || echo 0)
                case "$attempts" in ''|*[!0-9]*) attempts=0 ;; esac
            fi
        fi
        if [ "$attempts" -ge "$max_attempts" ]; then
            log "transcribe gave_up attempts=$attempts file=$file"
            transcribe_gave_up=$((transcribe_gave_up + 1))
            continue
        fi

        log "transcribe begin: $file"
        if transcribe -p "@$prompt_file" \
                      -m "$transcribe_model" \
                      -o "${file}.txt" "$file" >>"$log_file" 2>&1; then
            log "transcribe ok: $file"
            rm -f "$fail_file"

            # Archive the audio. ~/Recordings (iCloud) and the archive are on
            # different volumes, so a plain mv is a non-atomic copy+unlink:
            # copy to a temp on the destination volume, rename into place
            # (atomic, same volume), then remove the source. A pre-existing
            # target is treated as an error rather than silently overwritten.
            # The transcript (.txt) stays in ~/Recordings to sync via iCloud.
            dest="$archive_dir/$base"
            tmp="$archive_dir/.$base.part"
            if [ -e "$dest" ]; then
                log "ERROR archive reason=target_exists file=$file dest=$dest"
                archive_failed=$((archive_failed + 1))
                exit_code=1
            elif cp -p "$file" "$tmp" >>"$log_file" 2>&1 \
                    && mv "$tmp" "$dest" >>"$log_file" 2>&1; then
                rm -f "$file"
                log "archived: $base -> $archive_dir"
                transcribed=$((transcribed + 1))
            else
                rc=$?
                rm -f "$tmp"
                log "ERROR archive rc=$rc file=$file"
                archive_failed=$((archive_failed + 1))
                exit_code=1
            fi
        else
            rc=$?
            log "ERROR transcribe rc=$rc file=$file"
            rm -f "${file}.txt"
            printf '%s\n' "$((attempts + 1))" >"$fail_file"
            transcribe_failed=$((transcribe_failed + 1))
            exit_code=1
        fi
    done
fi
