#!/usr/bin/env bash
set -euo pipefail

CODEX_MODEL=${CODEX_MODEL:-gpt-5.5}
CLAUDE_MODEL=${CLAUDE_MODEL:-claude-fable-5}

usage() {
    printf 'Usage: %s {codex|claude} WORKDIR [TITLE]\n' "${0##*/}" >&2
    exit 2
}

if [[ $# -lt 2 || $# -gt 3 ]]; then
    usage
fi

if ! command -v jq >/dev/null 2>&1; then
    printf '%s: jq is required to parse agent-deck --json output\n' "${0##*/}" >&2
    exit 1
fi

TOOL=$1
WORKDIR=${2/#\~/$HOME}

if [[ ! -d "$WORKDIR" ]]; then
    printf '%s: workdir does not exist: %s\n' "${0##*/}" "$WORKDIR" >&2
    exit 1
fi

WORKDIR=$(cd "$WORKDIR" && pwd -P)
TITLE=${3:-$(basename "$WORKDIR")}

case "$TOOL" in
    codex)
        add_json=$(agent-deck add                                               \
                              --json                                            \
                              -c codex                                          \
                              --yolo                                            \
                              --model "$CODEX_MODEL"                            \
                              -t "$TITLE"                                       \
                              "$WORKDIR")
        ;;

    claude)
        add_json=$(agent-deck add                                               \
                              --json                                            \
                              -c claude                                         \
                              --extra-arg=--effort                              \
                              --extra-arg=max                                   \
                              --extra-arg=--dangerously-skip-permissions        \
                              --model "$CLAUDE_MODEL"                           \
                              -t "$TITLE"                                       \
                              "$WORKDIR")
        ;;

    *)
        usage
        ;;
esac

session_id=$(jq -er '.id' <<<"$add_json")
agent-deck session start "$session_id"
